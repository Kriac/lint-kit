{
  "include": ["src"],
  "compilerOptions": {
    "types": ["vite/client"],

    "target": "ESNext",
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",

    "jsx": "preserve",

    "noEmit": true,
    "skipLibCheck": true,

    "strict": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  }
}
